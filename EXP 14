# Alpha-Beta Pruning Algorithm Example

MAX = 1000
MIN = -1000

# Function to implement Alpha-Beta Pruning
def alphabeta(depth, node_index, maximizing_player,
              values, alpha, beta, max_depth):

    # Base case: leaf node reached
    if depth == max_depth:
        return values[node_index]

    if maximizing_player:
        best = MIN

        # Left and right children
        for i in range(2):
            val = alphabeta(depth + 1,
                            node_index * 2 + i,
                            False, values,
                            alpha, beta, max_depth)

            best = max(best, val)
            alpha = max(alpha, best)

            # Alpha-Beta Pruning
            if beta <= alpha:
                break

        return best

    else:
        best = MAX

        # Left and right children
        for i in range(2):
            val = alphabeta(depth + 1,
                            node_index * 2 + i,
                            True, values,
                            alpha, beta, max_depth)

            best = min(best, val)
            beta = min(beta, best)

            # Alpha-Beta Pruning
            if beta <= alpha:
                break

        return best

# Driver code

# Leaf node values
values = [3, 5, 6, 9, 1, 2, 0, -1]

# Tree depth
max_depth = 3

result = alphabeta(0, 0, True, values, MIN, MAX, max_depth)

print("Optimal value using Alpha-Beta Pruning is:", result)
